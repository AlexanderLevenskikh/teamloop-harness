{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Antipattern",
  "description": "An antipattern to avoid in future work",
  "type": "object",
  "required": ["schemaVersion", "antipatternId", "title", "description", "status", "createdAtUtc"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "antipatternId": { "type": "string", "pattern": "^antipattern-[a-zA-Z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "DEPRECATED", "REJECTED", "SUPERSEDED"]
    },
    "evidenceIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^evidence-[a-zA-Z0-9-]+$" },
      "minItems": 1
    },
    "context": { "type": "string" },
    "createdAtUtc": { "type": "string", "format": "date-time" },
    "deprecatedAtUtc": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
