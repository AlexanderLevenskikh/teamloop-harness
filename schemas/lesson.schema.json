{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lesson",
  "description": "A learned lesson that guides future work",
  "type": "object",
  "required": ["schemaVersion", "lessonId", "title", "description", "status", "createdAtUtc"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "lessonId": { "type": "string", "pattern": "^lesson-[a-zA-Z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "DEPRECATED", "REJECTED", "SUPERSEDED"]
    },
    "evidenceIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^evidence-[a-zA-Z0-9-]+$" },
      "minItems": 1
    },
    "category": { "type": "string" },
    "createdAtUtc": { "type": "string", "format": "date-time" },
    "deprecatedAtUtc": { "type": "string", "format": "date-time" },
    "supersededBy": { "type": "string", "pattern": "^lesson-[a-zA-Z0-9-]+$" }
  },
  "additionalProperties": false
}
