{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BoundaryPacket",
  "type": "object",
  "required": ["schemaVersion", "boundaryId", "profile", "deliverables", "validations", "hardInvariants", "softDebt", "rootPatterns", "improvementCandidates", "metrics", "remainingProfileBudget", "consecutiveNoProgressCycles", "primaryArtifactFingerprint", "validationEvidenceFingerprint", "metricsFingerprint", "configFingerprint", "policyFingerprint", "toolCompatibilityFingerprint", "packetFingerprint"],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 1},
    "boundaryId": {"type": "string"},
    "taskId": {"type": "string"},
    "runId": {"type": "string"},
    "adapterId": {"type": "string"},
    "profile": {"type": "string", "enum": ["fast", "standard", "audit"]},
    "measuredAtUtc": {"type": "string", "format": "date-time"},
    "deliverables": {"type": "array"},
    "validations": {"type": "array"},
    "hardInvariants": {"type": "array"},
    "softDebt": {"type": "array"},
    "rootPatterns": {"type": "array"},
    "improvementCandidates": {"type": "array"},
    "metrics": {"type": "object"},
    "delta": {"type": "object"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty": {"type": "array"},
    "remainingProfileBudget": {"type": "integer", "minimum": 0},
    "consecutiveNoProgressCycles": {"type": "integer", "minimum": 0},
    "primaryArtifactFingerprint": {"type": "string", "minLength": 64},
    "validationEvidenceFingerprint": {"type": "string", "minLength": 64},
    "metricsFingerprint": {"type": "string", "minLength": 64},
    "configFingerprint": {"type": "string", "minLength": 64},
    "policyFingerprint": {"type": "string", "minLength": 64},
    "toolCompatibilityFingerprint": {"type": "string", "minLength": 64},
    "retainedDiagnostics": {"type": "object"},
    "packetFingerprint": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
