{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionManifest",
  "type": "object",
  "required": ["schemaVersion", "schemaId", "runId", "taskId", "taskRevision", "repositoryHead", "executionProfile", "allowedRoots", "allowedFiles", "forbiddenRoots", "forbiddenOperations", "allowedCommandClasses", "requiredGates", "requiredEvidence", "protectedPathStatus", "policyFingerprint", "sourceFingerprints", "createdAtUtc", "semanticFingerprint", "integrity"],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 1},
    "schemaId": {"type": "string", "const": "teamloop-execution-manifest/v1"},
    "runId": {"type": "string", "pattern": "^run-"},
    "taskId": {"type": "string", "pattern": "^task-"},
    "taskRevision": {"type": "string", "minLength": 64},
    "repositoryHead": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "executionProfile": {"type": "string", "enum": ["fast", "standard", "audit"]},
    "allowedRoots": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "allowedFiles": {"type": "array", "items": {"type": "string"}},
    "forbiddenRoots": {"type": "array", "items": {"type": "string"}},
    "forbiddenOperations": {"type": "array", "items": {"type": "string"}},
    "allowedCommandClasses": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "requiredGates": {"type": "array", "items": {"type": "string"}},
    "requiredEvidence": {"type": "array", "items": {"type": "string"}},
    "protectedPathStatus": {"type": "string", "enum": ["CLEAN", "PROTECTED_SCOPE", "NOT_CONFIGURED"]},
    "policyFingerprint": {"type": "string", "minLength": 64},
    "sourceFingerprints": {"type": "object"},
    "createdAtUtc": {"type": "string", "format": "date-time"},
    "semanticFingerprint": {"type": "string", "minLength": 64},
    "integrity": {
      "type": "object",
      "required": ["algorithm", "semanticSha256"],
      "properties": {
        "algorithm": {"type": "string", "const": "sha256"},
        "semanticSha256": {"type": "string", "minLength": 64}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
