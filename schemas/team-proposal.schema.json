{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://your-ai-team.dev/schemas/team-proposal.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "product",
    "proposalId",
    "status",
    "task",
    "analysis",
    "constraints",
    "team",
    "budget",
    "tradeoffs",
    "acceptance",
    "fingerprint"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "product": {
      "type": "string",
      "const": "YourAITeam"
    },
    "proposalId": {
      "type": "string",
      "minLength": 6
    },
    "status": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "BUDGET_UNSATISFIED",
        "ACCEPTED"
      ]
    },
    "task": {
      "type": "object"
    },
    "analysis": {
      "type": "object"
    },
    "constraints": {
      "type": "object"
    },
    "team": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "budget": {
      "type": "object"
    },
    "tradeoffs": {
      "type": "array"
    },
    "acceptance": {
      "type": "object"
    },
    "fingerprint": {
      "type": "string",
      "minLength": 64
    }
  },
  "additionalProperties": true
}
