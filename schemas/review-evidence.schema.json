{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewEvidence",
  "description": "Content-addressed review evidence recorded when a task passes review or gates",
  "type": "object",
  "required": ["schemaVersion", "taskId", "reviewedAtUtc", "reviewedFiles", "reviewResult", "reviewer"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "taskId": { "type": "string" },
    "reviewedAtUtc": { "type": "string", "pattern": "^[0-9]{4}-" },
    "reviewedCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "reviewedFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "hash", "status"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "status": {
            "type": "string",
            "enum": ["TRACKED", "UNTRACKED"]
          }
        }
      }
    },
    "reviewResult": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "gateResult": { "type": "string" },
    "reviewer": { "type": "string" }
  }
}
