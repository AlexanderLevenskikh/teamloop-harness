{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReleaseMetadata",
  "description": "Release metadata for a YourAITeam version",
  "type": "object",
  "required": ["schemaVersion", "version", "releaseDate", "summary"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "releaseDate": {
      "type": "string",
      "format": "date"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "title", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["feature", "fix", "refactor", "docs", "chore", "breaking"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "breakingChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description", "migration"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "migration": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "compatibilityNotes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
