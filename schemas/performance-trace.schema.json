{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PerformanceTrace",
  "type": "object",
  "required": ["schemaVersion", "schemaId", "runId", "phases", "totalDurationMs", "processInvocationCount", "roleInvocationCount", "filesReadOrValidated", "createdAtUtc", "updatedAtUtc"],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 1},
    "schemaId": {"type": "string", "const": "teamloop-performance-trace/v1"},
    "runId": {"type": "string"},
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "durationMs", "processInvocationCount", "roleInvocationCount", "decision"],
        "properties": {
          "phase": {"type": "string"},
          "durationMs": {"type": "number"},
          "processInvocationCount": {"type": "integer"},
          "roleInvocationCount": {"type": "integer"},
          "decision": {"type": "string", "enum": ["EXECUTED", "REUSED", "NO_OP", "FAILED"]},
          "filesReadOrValidated": {"type": "array", "items": {"type": "string"}},
          "details": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "totalDurationMs": {"type": "number"},
    "processInvocationCount": {"type": "integer"},
    "roleInvocationCount": {"type": "integer"},
    "filesReadOrValidated": {"type": "array", "items": {"type": "string"}},
    "createdAtUtc": {"type": "string", "format": "date-time"},
    "updatedAtUtc": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
