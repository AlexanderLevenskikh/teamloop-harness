{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DogfoodReport",
  "description": "Structured report produced by the dogfood command that runs the full gate chain on a workspace",
  "type": "object",
  "required": ["schemaVersion", "checkedAtUtc", "overallStatus", "checks"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "checkedAtUtc": { "type": "string", "pattern": "^[0-9]{4}-" },
    "overallStatus": {
      "type": "string",
      "enum": ["PASS", "FAIL", "ERROR"]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "summary"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL", "ERROR", "SKIPPED"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "detail": { "type": "string" }
        }
      }
    },
    "oldNewCompare": {
      "type": "object",
      "required": ["direct", "context", "differences"],
      "additionalProperties": false,
      "properties": {
        "direct": {
          "type": "object",
          "required": ["overallStatus", "checks"],
          "additionalProperties": false,
          "properties": {
            "overallStatus": { "type": "string" },
            "checks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "status"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "status": { "type": "string" },
                  "summary": { "type": "string" },
                  "detail": { "type": "string" }
                }
              }
            }
          }
        },
        "context": {
          "type": "object",
          "required": ["overallStatus", "checks"],
          "additionalProperties": false,
          "properties": {
            "overallStatus": { "type": "string" },
            "checks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "status"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "status": { "type": "string" },
                  "summary": { "type": "string" },
                  "detail": { "type": "string" }
                }
              }
            }
          }
        },
        "differences": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check", "directStatus", "contextStatus"],
            "additionalProperties": false,
            "properties": {
              "check": { "type": "string" },
              "directStatus": { "type": "string" },
              "contextStatus": { "type": "string" },
              "directSummary": { "type": "string" },
              "contextSummary": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
