{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GateResult",
  "description": "Gatekeeper gate execution result",
  "type": "object",
  "required": ["schemaVersion", "runId", "taskId", "status", "checks"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runId": { "type": "string", "pattern": "^run-" },
    "taskId": { "type": "string", "pattern": "^task-" },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "SKIPPED", "ERROR"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "SKIPPED", "ERROR"] },
          "command": { "type": "string" },
          "exitCode": { "type": "integer" },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "nextAction": { "type": "string" },
    "humanRequired": { "type": "boolean", "default": false }
  },
  "additionalProperties": false
}
